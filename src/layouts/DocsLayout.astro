---
interface Props {
  title: string;
}
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 1rem;
        line-height: 1.6;
        color: #1b1b1b;
        background: #fff;
      }

      header {
        background: #1a3a5c;
        color: #fff;
        padding: 0 2rem;
      }

      .header-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 2rem;
        height: 56px;
      }

      .site-name {
        font-weight: 700;
        font-size: 1.1rem;
        color: #fff;
        text-decoration: none;
      }

      nav a {
        color: rgba(255,255,255,0.85);
        text-decoration: none;
        font-size: 0.9rem;
      }

      nav a:hover {
        color: #fff;
      }

      .layout {
        display: flex;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        gap: 3rem;
      }

      aside {
        width: 220px;
        flex-shrink: 0;
        padding-top: 2rem;
      }

      aside nav {
        position: sticky;
        top: 2rem;
      }

      aside h2 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #71767a;
        margin: 0 0 0.5rem;
      }

      aside ul {
        list-style: none;
        margin: 0 0 1.5rem;
        padding: 0;
      }

      aside li a {
        display: block;
        padding: 3px 0;
        color: #1b1b1b;
        text-decoration: none;
        font-size: 0.9rem;
      }

      aside li a:hover,
      aside li a[aria-current="page"] {
        color: #1a6faf;
        font-weight: 600;
      }

      main {
        flex: 1;
        min-width: 0;
        padding: 2rem 0 4rem;
      }

      main h1 {
        margin-top: 0;
        font-size: 2rem;
        border-bottom: 1px solid #dfe1e2;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
      }

      main h2 {
        font-size: 1.3rem;
        margin-top: 2.5rem;
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 0.25rem;
      }

      main h3 {
        font-size: 1.05rem;
        margin-top: 1.5rem;
      }

      code {
        font-family: 'Fira Code', 'Cascadia Code', monospace;
        font-size: 0.875em;
        background: #f5f5f5;
        padding: 0.15em 0.35em;
        border-radius: 3px;
      }

      pre {
        background: #f5f5f5;
        border: 1px solid #dfe1e2;
        border-radius: 4px;
        padding: 1rem 1.25rem;
        overflow-x: auto;
        font-size: 0.875rem;
      }

      pre code {
        background: none;
        padding: 0;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        margin: 1rem 0;
      }

      th, td {
        text-align: left;
        padding: 8px 12px;
        border-bottom: 1px solid #dfe1e2;
      }

      th {
        background: #f5f5f5;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="site-name">CivicKit</a>
        <nav aria-label="Site">
          <a href="/components/alert">Components</a>
        </nav>
      </div>
    </header>

    <div class="layout">
      <aside>
        <nav aria-label="Components">
          <h2>Components</h2>
          <ul>
            <li><a href="/components/alert" aria-current={currentPath === '/components/alert' ? 'page' : undefined}>Alert</a></li>
          </ul>
        </nav>
      </aside>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
